# Large local data and generated reconstruction artifacts.
# Keep directory READMEs/manifests in git, keep payloads local.
data/raw/**
!data/raw/
!data/raw/README.md
!data/raw/.gitkeep
data/interim/**
!data/interim/
!data/interim/README.md
!data/interim/.gitkeep
data/processed/**
!data/processed/
!data/processed/README.md
!data/processed/.gitkeep
artifacts/**
!artifacts/
!artifacts/README.md
!artifacts/.gitkeep
exports/**
!exports/
!exports/README.md
!exports/.gitkeep
captures/**
!captures/
!captures/README.md
!captures/.gitkeep

# User-provided/private assets stay local unless explicitly approved.
assets/private/**
!assets/private/
!assets/private/README.md
!assets/private/.gitkeep
assets/user-provided/**
!assets/user-provided/
!assets/user-provided/README.md
!assets/user-provided/.gitkeep

