# Local paths. Copy to `.env` if scripts need local overrides.

REALWORLD_DATA_ROOT=data
REALWORLD_ARTIFACTS_ROOT=artifacts
REALWORLD_ASSETS_ROOT=assets
REALWORLD_WINDOWS_DATA_ROOT=
REALWORLD_UNITY_PROJECT=unity
REALWORLD_UNITY_PROJECT_WINDOWS=

# Privacy boundary. Keep false unless the user explicitly approves cloud use.
REALWORLD_ALLOW_CLOUD_PROCESSING=false

# Optional user-provided asset path. Do not commit the asset file by default.
REALWORLD_REFINERY_ROOT=
REALWORLD_REFINERY_ROOT_WINDOWS=
REALWORLD_REFINERY_GLB_DIR=
REALWORLD_REFINERY_GAP_FALLBACK_FBX=
REALWORLD_REFINERY_GLB=
REALWORLD_REFINERY_SCHEDULE_CSV=
REALWORLD_REFINERY_SCHEDULE_ENCODING=cp949
